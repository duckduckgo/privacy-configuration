{
    "_meta": {
        "description": "Manipulates DOM APIs in the page"
    },
    "state": "enabled",
    "exceptions": [],
    "settings": {
        "apiChanges": {},
        "conditionalChanges": [
            {
                "condition": {
                    "domain": "naturium.com"
                },
                "patchSettings": [
                    {
                        "op": "add",
                        "path": "/apiChanges/Navigator.prototype.globalPrivacyControl",
                        "value": {
                            "type": "descriptor",
                            "getterValue": {
                                "type": "boolean",
                                "value": false
                            },
                            "configurable": true,
                            "enumerable": true
                        }
                    }
                ]
            }
        ]
    }
}
